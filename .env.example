# ============================================================
# OSINT NEXUS — Environment Configuration
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================================

# ------------------------------------------------------------
# Required — the stack will refuse to start without these
# ------------------------------------------------------------
POSTGRES_PASSWORD=your-strong-postgres-password
NEO4J_PASSWORD=your-strong-neo4j-password
AUTH_SECRET=your-min-32-char-random-secret
AUTH_DEFAULT_ADMIN_PASSWORD=your-admin-password

# ------------------------------------------------------------
# Admin account
# ------------------------------------------------------------
AUTH_DEFAULT_ADMIN_USER=admin

# ------------------------------------------------------------
# Database (auto-constructed from POSTGRES_PASSWORD if left blank)
# ------------------------------------------------------------
DATABASE_URL=postgresql://osint:${POSTGRES_PASSWORD}@postgres:5432/osint

# ------------------------------------------------------------
# Observability (Grafana admin password — prod profile only)
# ------------------------------------------------------------
GRAFANA_PASSWORD=your-grafana-admin-password

# ------------------------------------------------------------
# API Keys — optional but needed for live data feeds
# ------------------------------------------------------------
AISSTREAM_API_KEY=           # https://aisstream.io
FIRMS_MAP_KEY=               # https://firms.modaps.eosdis.nasa.gov/api/

# ------------------------------------------------------------
# Data source toggles (1=on, 0=off)
# ------------------------------------------------------------
ENABLE_ADSBLOL=1
ENABLE_AISSTREAM=1
ENABLE_FIRMS=1

# ------------------------------------------------------------
# Network (set to your LAN IP if accessing from other devices)
# ------------------------------------------------------------
LOCAL_IP=127.0.0.1

# ------------------------------------------------------------
# Auth mode
# 1 = admin login requires a registered passkey (recommended)
# 0 = password-only (development only)
# ------------------------------------------------------------
AUTH_ADMIN_REQUIRE_PASSKEY=1
AUTH_COOKIE_SECURE=0

# ------------------------------------------------------------
# Passkey / WebAuthn (must match your domain in production)
# ------------------------------------------------------------
PASSKEY_RP_ID=localhost
PASSKEY_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ------------------------------------------------------------
# Emergency break-glass code (bypasses passkey for admin)
# ------------------------------------------------------------
AUTH_BREAK_GLASS_CODE=

# ------------------------------------------------------------
# AI models (Ollama must be running with these pulled)
# pull with: docker compose exec ollama ollama pull llama3.1:8b
#            docker compose exec ollama ollama pull phi4-mini
# ------------------------------------------------------------
OLLAMA_MODEL=llama3.1:8b
OLLAMA_FALLBACK_MODEL=llama3.1:8b
V2_MODEL_VERIFY=phi4-mini
V2_MODEL_REPORT=llama3.1:8b
V2_MODEL_DEFAULT=phi4-mini

# ------------------------------------------------------------
# Data polling intervals
# ------------------------------------------------------------
AISSTREAM_BBOX=30,12,63,40
FIRMS_BBOX=30,12,63,40
FIRMS_SOURCE=VIIRS_SNPP_NRT
FIRMS_DAYS=1
FIRMS_POLL_INTERVAL_SEC=180
ADSBLOL_API_URL=https://api.adsb.lol/v2/mil
ADSBLOL_POLL_INTERVAL_SEC=12
AISSTREAM_WS_URL=wss://stream.aisstream.io/v0/stream
