AUTH_SECRET=replace-with-min-32-char-random-secret
AUTH_DEFAULT_ADMIN_USER=admin
AUTH_DEFAULT_ADMIN_PASSWORD=Admin!ChangeMe123
AUTH_COOKIE_SECURE=0
AUTH_ADMIN_REQUIRE_PASSKEY=1
AUTH_BREAK_GLASS_CODE=
ALLOW_INSECURE_DEFAULTS=0

POSTGRES_PASSWORD=change-me-postgres-password
DATABASE_URL=postgresql://osint:${POSTGRES_PASSWORD}@postgres:5432/osint

ENABLE_ADSBLOL=1
ADSBLOL_API_URL=https://api.adsb.lol/v2/mil
ADSBLOL_POLL_INTERVAL_SEC=12

ENABLE_AISSTREAM=1
AISSTREAM_WS_URL=wss://stream.aisstream.io/v0/stream
AISSTREAM_API_KEY=
AISSTREAM_BBOX=30,12,63,40

ENABLE_FIRMS=1
FIRMS_MAP_KEY=
FIRMS_SOURCE=VIIRS_SNPP_NRT
FIRMS_BBOX=30,12,63,40
FIRMS_DAYS=1
FIRMS_POLL_INTERVAL_SEC=180

WHISPER_HOOK_URL=http://media-hooks:8090/hooks/whisper
DEEPFAKE_HOOK_URL=http://media-hooks:8090/hooks/deepfake
MEDIA_HOOK_TIMEOUT_SEC=35

WHISPER_MODEL=small
WHISPER_DEVICE=cuda
WHISPER_COMPUTE_TYPE=int8_float16
WHISPER_BEAM_SIZE=2
WHISPER_MAX_SECONDS=240
